{
    "version": 8,
    "configurePresets": [
        {
            "name": "FrameLift",
            "displayName": "FrameLift (Linux / system deps)",
            "description": "Ninja generator; FFmpeg/libass/Qt6 from system packages (no vcpkg).",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "FRAMELIFT_MODULE_GRAPHICS_VULKAN": "OFF"
            }
        },
        {
            "name": "FrameLift-windows",
            "displayName": "FrameLift (Windows / vcpkg)",
            "description": "Inherits FrameLift; resolves deps through the vcpkg toolchain.",
            "inherits": "FrameLift",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        }
    ]
}
