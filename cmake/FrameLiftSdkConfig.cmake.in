@PACKAGE_INIT@

# FrameLift plugin SDK package config (installed into <prefix>/cmake/).
#
# Usage from a plugin's CMakeLists.txt:
#   find_package(FrameLiftSdk REQUIRED)
#   add_framelift_plugin(MyPlugin
#       PLUGIN_JSON "${CMAKE_CURRENT_SOURCE_DIR}/MyPlugin.Plugin.json"
#       MyPlugin.cpp ${FRAMELIFT_SDK_SOURCES})
#
# A runtime plugin DLL/SO is a Qt plugin (QPluginLoader + Q_PLUGIN_METADATA via IPlugin), so
# the SDK requires Qt6::Core — the historical imgui/json-free rule no longer
# implies Qt-free. find_package compatibility is gated on the ABI version via the
# accompanying FrameLiftSdkConfigVersion.cmake (ExactVersion); the runtime loader
# enforces the same exact-version match before instantiating a plugin.

include(CMakeFindDependencyMacro)
find_dependency(Qt6 COMPONENTS Core Qml Quick QuickControls2)

set(FRAMELIFT_SDK_STANDALONE ON)
include("${CMAKE_CURRENT_LIST_DIR}/FrameLiftSdk.cmake")

check_required_components(FrameLiftSdk)
