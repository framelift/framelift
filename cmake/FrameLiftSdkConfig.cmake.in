@PACKAGE_INIT@

# FrameLift plugin SDK package config (installed into <prefix>/cmake/).
#
# Usage from a plugin's CMakeLists.txt:
#   find_package(FrameLiftSdk REQUIRED)
#   add_framelift_plugin(MyPlugin MyPlugin.cpp ${FRAMELIFT_SDK_SOURCES})
#
# The SDK is dependency-free: no imgui/spdlog/stb/json are required to build a
# plugin. find_package compatibility is gated on the ABI major version via the
# accompanying FrameLiftSdkConfigVersion.cmake (SameMajorVersion); the runtime loader
# additionally enforces minor compatibility (host.minor >= plugin.minor).

set(FRAMELIFT_SDK_STANDALONE ON)
include("${CMAKE_CURRENT_LIST_DIR}/FrameLiftSdk.cmake")

check_required_components(FrameLiftSdk)
